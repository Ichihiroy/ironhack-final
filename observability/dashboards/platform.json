{
  "title": "Platform — pods, nodes, HPA, deployments",
  "uid": "platform",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["platform"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Pod CPU (cores) — app namespaces",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (namespace, pod) (rate(container_cpu_usage_seconds_total{namespace=~\"app-.*\", container!=\"\"}[2m]))",
          "legendFormat": "{{namespace}}/{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Pod memory (working set) — app namespaces",
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (namespace, pod) (container_memory_working_set_bytes{namespace=~\"app-.*\", container!=\"\"})",
          "legendFormat": "{{namespace}}/{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Node CPU utilisation",
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m]))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Node memory utilisation",
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HPA — current vs desired vs max (the load-test hero panel)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=~\"app-.*\"}",
          "legendFormat": "{{namespace}}/{{horizontalpodautoscaler}} current",
          "refId": "A"
        },
        {
          "expr": "kube_horizontalpodautoscaler_status_desired_replicas{namespace=~\"app-.*\"}",
          "legendFormat": "{{namespace}}/{{horizontalpodautoscaler}} desired",
          "refId": "B"
        },
        {
          "expr": "kube_horizontalpodautoscaler_spec_max_replicas{namespace=~\"app-.*\"}",
          "legendFormat": "{{namespace}}/{{horizontalpodautoscaler}} max",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Container restarts (15m increase)",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "increase(kube_pod_container_status_restarts_total{namespace=~\"app-.*\"}[15m])",
          "legendFormat": "{{namespace}}/{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Deployment status — available vs desired",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_available{namespace=~\"app-.*\"}",
          "legendFormat": "{{namespace}}/{{deployment}} available",
          "refId": "A"
        },
        {
          "expr": "kube_deployment_spec_replicas{namespace=~\"app-.*\"}",
          "legendFormat": "{{namespace}}/{{deployment}} desired",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Saturation — memory vs limit (app namespaces)",
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "max by (namespace, pod, container) (container_memory_working_set_bytes{namespace=~\"app-.*\", container!=\"\"}) / max by (namespace, pod, container) (kube_pod_container_resource_limits{namespace=~\"app-.*\", resource=\"memory\"})",
          "legendFormat": "{{namespace}}/{{pod}}/{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Saturation — CPU throttling ratio (app namespaces)",
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "sum by (namespace, pod, container) (increase(container_cpu_cfs_throttled_periods_total{namespace=~\"app-.*\", container!=\"\"}[5m])) / sum by (namespace, pod, container) (increase(container_cpu_cfs_periods_total{namespace=~\"app-.*\", container!=\"\"}[5m]))",
          "legendFormat": "{{namespace}}/{{pod}}/{{container}} throttled",
          "refId": "A"
        }
      ]
    }
  ]
}
